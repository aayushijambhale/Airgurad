# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<dbname>?retryWrites=true&w=majority

# Database name used by the app (optional, defaults to "airguard")
MONGODB_DB=airguard

# Auth token signing secret (use a long random value)
AUTH_SECRET=replace-with-a-long-random-secret

# Local server port (optional, defaults to 3001)
PORT=3001
